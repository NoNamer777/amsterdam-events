    "@angular/platform-browser": "~21.0",
    "@angular/router": "~21.0",
    "bootstrap": "~5.3",
    "rxjs": "~7.8",
    "tslib": "~2.8"
  },
  "devDependencies": {
    "@analogjs/platform": "~2.1",
    "@analogjs/vite-plugin-angular": "~2.1",
    "@analogjs/vitest-angular": "~2.1",
